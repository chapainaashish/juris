  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// Set dynamic variables if needed",
          "// Example: Set current timestamp",
          "pm.environment.set('timestamp', Date.now());"
        ]
      }
    },
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// Common test scripts for subscription endpoints",
          "",
          "// Test for successful responses",
          "pm.test('Status code is successful', function () {",
          "    pm.expect(pm.response.code).to.be.oneOf([200, 201, 204]);",
          "});",
          "",
          "// Save payment method ID from payment methods response",
          "if (pm.info.requestName === 'Get Payment Methods' && pm.response.code === 200) {",
          "    const responseJson = pm.response.json();",
          "    if (responseJson.length > 0 && responseJson[0].stripe_payment_method_id) {",
          "        pm.environment.set('payment_method_id', responseJson[0].stripe_payment_method_id);",
          "        console.log('Payment method ID updated:', responseJson[0].stripe_payment_method_id);",
          "    }",
          "}",
          "",
          "// Save subscription details",
          "if (pm.info.requestName === 'Get Vendor Subscription' && pm.response.code === 200) {",
          "    const responseJson = pm.response.json();",
          "    if (responseJson.subscription_id) {",
          "        pm.environment.set('subscription_id', responseJson.subscription_id);",
          "        console.log('Subscription ID saved:', responseJson.subscription_id);",
          "    }",
          "}",
          "",
          "// Log response for debugging",
          "if (pm.response.code >= 400) {",
          "    console.log('Error response:', pm.response.text());",
          "}"
        ]
      }
    }
