# Basic Details
SITE_NAME="Juris"
FRONTEND_URL="http://localhost:5173"

# Database
POSTGRES_DB="juris"
POSTGRES_USER="juris"
POSTGRES_PASSWORD="postgres_password"
POSTGRES_HOST="db"
POSTGRES_PORT=5432

# Redis configuration
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# Django settings
DJANGO_SECRET_KEY="django_secret_key"
DEBUG=False
ALLOWED_HOSTS=*
DJANGO_SETTINGS_MODULE=juris.settings
DRF_PAGE_SIZE=20
DRF_MAX_PAGE_SIZE=100
JWT_SIGNING_KEY=your_jwt_signing_key

# Authentication and security
MIN_PASSWORD_LENGTH=10
SESSION_COOKIE_AGE=43200
ACCESS_TOKEN_LIFETIME_MINUTES=600
REFRESH_TOKEN_LIFETIME_DAYS=1
ANON_THROTTLE_RATE=20/minute
USER_THROTTLE_RATE=60/minute
MAX_LOGIN_ATTEMPTS=5
LOGIN_LOCKOUT_TIME_MINUTES=30
PASSWORD_RESET_TIMEOUT=86400

# OTP constants
MAX_OTP_ATTEMPTS=5
OTP_LOCKOUT_TIME_MINUTES=30
RESEND_COOLDOWN_SECONDS=60
OTP_VALIDITY_MINUTES=5
OTP_CODE_LENGTH=6

# Lawyer Appointment Constants
APPOINTMENT_EXPIRATION_MINUTES=10
REFUND_COMMISSION_PERCENTAGE=5

# Email configuration (SendGrid)
EMAIL_HOST="smtp.sendgrid.net"
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER="apikey"
EMAIL_HOST_PASSWORD="sendgrid_api_key"
DEFAULT_FROM_EMAIL="info@juris.com"
EMAIL_VERIFICATION_VALID_UNTIL_HOURS=48
EMAIL_VERIFICATION_SUCCESS_URL="http://localhost:5173/email/verify/success"
EMAIL_VERIFICATION_FAILURE_URL="http://localhost:5173/email/verify/failed"
SENDGRID_API_KEY="sendgrid_api_key"

# Twilio configuration
TWILIO_ACCOUNT_SID="twilio_account_sid"
TWILIO_AUTH_TOKEN="twilio_auth_token"
TWILIO_PHONE_NUMBER="+1xxxxxxxxxx"

# Agora
AGORA_APP_ID=your_agora_app_id
AGORA_APP_CERTIFICATE=your_agora_app_certificate

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Stripe
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_CURRENCY='USD'
TRIAL_PERIOD_DAYS=15
NOTIFY_BEFORE_DAYS=2

# Google OAuth2
SOCIAL_AUTH_GOOGLE_OAUTH2_KEY="google_client_id"
SOCIAL_AUTH_GOOGLE_OAUTH2_SECRET="google_client_secret"
SOCIAL_AUTH_GOOGLE_OAUTH2_SCOPE="email,profile"

# CORS settings
CORS_ALLOWED_ORIGINS="http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173"
